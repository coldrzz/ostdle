# IGDB API (via Twitch) - https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# Backend
PORT=3001
NODE_ENV=development

# Python media service
PYTHON_SERVICE_URL=http://localhost:5001
PYTHON_SERVICE_PORT=5001

# YouTube — evita el error "Sign in to confirm you're not a bot"
YTDLP_COOKIES_FROM_BROWSER=chrome

# Ruta a ffmpeg si no está en PATH (opcional)
# FFMPEG_LOCATION=C:\ffmpeg\bin

# Frontend (Vite)
VITE_API_URL=http://localhost:3001/api
